---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MIX・マスタリング依頼 | きゃるのページ">
  <div class="mix-page">
    <!-- Hero -->
    <div class="mix-hero">
      <div class="mix-hero-content">
        <h1 class="mix-hero-title">MIX・マスタリング</h1>
        <p class="mix-hero-subtitle">Vocal MIX Service</p>
      </div>
    </div>

    <!-- Main Content -->
    <div class="mix-body">
      <div class="mix-container">

        <!-- サービス概要 -->
        <section class="mix-section reveal">
          <div class="section-label-bg">Service</div>
          <h2 class="mix-section-title">サービス概要</h2>
          <div class="service-card">
            <p class="service-description">
              自身も歌い手として活動する出品者が、<strong>歌心を活かした歌ってみたのボーカルMIX</strong>を提供するサービスです。
            </p>
            <div class="service-details">
              <div class="detail-item">
                <span class="detail-icon">🎛️</span>
                <div>
                  <h3>使用環境</h3>
                  <p>Logic Pro と Waves / iZotope / FabFilter などの外部プラグインを使用</p>
                </div>
              </div>
              <div class="detail-item">
                <span class="detail-icon">🎚️</span>
                <div>
                  <h3>トータルサポート</h3>
                  <p>ミキシングからマスタリングまで一貫して対応</p>
                </div>
              </div>
              <div class="detail-item">
                <span class="detail-icon">🎤</span>
                <div>
                  <h3>自然なピッチ補正</h3>
                  <p>「直しました感」がなく、歌の表現やニュアンスを損なわない仕上がりにこだわっています</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 料金 -->
        <section class="mix-section reveal">
          <div class="section-label-bg">Price</div>
          <h2 class="mix-section-title">料金体系</h2>

          <div class="pricing-card">
            <div class="pricing-header">
              <span class="pricing-label">基本プラン</span>
              <div class="pricing-amount">
                <span class="yen">¥</span><span class="price">5,000</span>
              </div>
              <span class="pricing-note">4分以内の楽曲</span>
            </div>
            <ul class="pricing-features">
              <li>MIX＆マスタリング（1曲）</li>
              <li>基本エフェクト処理（EQ・コンプレッション・リバーブ等）</li>
              <li>ノイズ除去</li>
              <li>音量バランス調整</li>
              <li>ピッチ補正</li>
              <li>タイミング補正</li>
            </ul>
          </div>

          <div class="options-grid">
            <div class="option-card">
              <h3>ハモリ・コーラスパートの追加MIX</h3>
              <p class="option-price">1パートにつき <strong>+¥1,000</strong></p>
            </div>
            <div class="option-card">
              <h3>4分を超える楽曲</h3>
              <p class="option-price">1分ごとに <strong>+¥1,000</strong></p>
              <p class="option-example">例：+1分で¥1,000、+2分で¥2,000</p>
            </div>
          </div>

          <div class="pricing-summary">
            <p>4分以内の楽曲なら<strong>5,000円</strong>で一通りのMIX作業が完結。長い曲やハモリを追加したい場合は<strong>1,000円単位</strong>で追加料金が発生するシンプルな料金設定です。</p>
          </div>
        </section>

        <!-- ご依頼の条件 -->
        <section class="mix-section reveal">
          <div class="section-label-bg">Info</div>
          <h2 class="mix-section-title">ご依頼について</h2>

          <div class="info-grid">
            <div class="info-card">
              <span class="info-icon">📅</span>
              <h3>納期</h3>
              <p>5〜7営業日<span class="info-sub">（目安7日）</span></p>
            </div>
            <div class="info-card">
              <span class="info-icon">🔄</span>
              <h3>無料修正回数</h3>
              <p>2回</p>
            </div>
            <div class="info-card">
              <span class="info-icon">🎵</span>
              <h3>対応ジャンル</h3>
              <p>ポップ、ロック、バラード、アニメ、ボカロ</p>
            </div>
            <div class="info-card">
              <span class="info-icon">📁</span>
              <h3>ファイル形式</h3>
              <p>WAV（44.1kHz）推奨</p>
            </div>
          </div>

          <div class="notice-card">
            <h3>購入前のお願い</h3>
            <p>購入前に必ず<strong>DMで相談</strong>し、音源と歌声データを送付の上、仕上がりのご希望をお伝えください。</p>
          </div>
        </section>

        <!-- 出品者情報 -->
        <section class="mix-section reveal">
          <div class="section-label-bg">Profile</div>
          <h2 class="mix-section-title">出品者情報</h2>

          <div class="profile-card">
            <div class="profile-stats">
              <div class="stat-item">
                <span class="stat-label">ランク</span>
                <span class="stat-value">レギュラー</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">総合評価</span>
                <span class="stat-value rating">⭐ 5.0<span class="stat-sub">（1件）</span></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">販売実績</span>
                <span class="stat-value">2件</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">経験</span>
                <span class="stat-value">クリエイター / 音楽家・歌手<span class="stat-sub">（2年）</span></span>
              </div>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="mix-section cta-section reveal">
          <h2 class="cta-heading">まずはお気軽にご相談ください</h2>
          <p class="cta-text">DMにて音源の確認・ご希望のヒアリングを行います</p>
          <a
            href="https://x.com/carrot_tpa"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-button"
          >
            <span class="cta-icon">𝕏</span>
            <span>DMで相談する</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
        </section>

      </div>
    </div>
  </div>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  /* ===== Page Base ===== */
  .mix-page {
    min-height: 100vh;
    background: var(--color-bg);
    color: var(--color-text);
  }

  /* ===== Hero ===== */
  .mix-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at 50% 50%, #1a1510 0%, var(--color-bg) 100%);
    position: relative;
    overflow: hidden;
  }

  .mix-hero::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 140, 66, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
  }

  .mix-hero-content {
    text-align: center;
    padding: 2rem;
    position: relative;
    z-index: 1;
    animation: fadeInUp 1s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mix-hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.03em;
  }

  .mix-hero-subtitle {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  /* ===== Body ===== */
  .mix-body {
    padding: 4rem 2rem;
    background: var(--color-bg-alt2);
  }

  .mix-container {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ===== Section ===== */
  .mix-section {
    margin-bottom: 5rem;
    position: relative;
  }

  .section-label-bg {
    font-size: 6rem;
    font-weight: 900;
    color: rgba(255, 180, 100, 0.04);
    text-transform: uppercase;
    line-height: 1;
    pointer-events: none;
    font-family: var(--font-heading);
    margin-bottom: -2rem;
  }

  .mix-section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2rem;
    padding-left: 1rem;
    position: relative;
  }

  .mix-section-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 70%;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* ===== Service Card ===== */
  .service-card {
    background: rgba(255, 180, 100, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    box-shadow:
      0 4px 0 rgba(13, 10, 7, 0.5),
      0 8px 25px rgba(0, 0, 0, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.03);
  }

  .service-description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    text-align: center;
  }

  .service-description strong {
    color: var(--color-text);
  }

  .service-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .detail-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    background: rgba(255, 180, 100, 0.02);
    border-radius: 14px;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }

  .detail-item:hover {
    background: rgba(255, 140, 66, 0.05);
    border-color: rgba(255, 140, 66, 0.2);
  }

  .detail-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .detail-item h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.3rem;
  }

  .detail-item p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ===== Pricing ===== */
  .pricing-card {
    background: rgba(255, 180, 100, 0.03);
    border: 2px solid rgba(255, 140, 66, 0.3);
    border-radius: 24px;
    overflow: hidden;
    margin-bottom: 2rem;
    box-shadow:
      0 4px 0 rgba(13, 10, 7, 0.5),
      0 8px 25px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(255, 140, 66, 0.08),
      inset 0 1px 2px rgba(255, 255, 255, 0.03);
  }

  .pricing-header {
    text-align: center;
    padding: 2.5rem 2rem 2rem;
    background: linear-gradient(180deg, rgba(255, 140, 66, 0.08) 0%, transparent 100%);
  }

  .pricing-label {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent2) 100%);
    color: #fff;
    padding: 0.35rem 1.25rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .pricing-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .yen {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .price {
    font-size: 3.5rem;
    font-weight: 800;
    font-family: var(--font-heading);
    color: var(--color-text);
    letter-spacing: -0.03em;
  }

  .pricing-note {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .pricing-features {
    list-style: none;
    padding: 1.5rem 2rem 2rem;
  }

  .pricing-features li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pricing-features li:last-child {
    border-bottom: none;
  }

  .pricing-features li::before {
    content: '✓';
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Options */
  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .option-card {
    background: rgba(255, 180, 100, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.75rem;
    transition: all 0.3s ease;
    box-shadow:
      0 3px 0 rgba(13, 10, 7, 0.4),
      0 6px 15px rgba(0, 0, 0, 0.2),
      inset 0 1px 2px rgba(255, 255, 255, 0.02);
  }

  .option-card:hover {
    border-color: rgba(255, 140, 66, 0.2);
    transform: translateY(-3px);
    box-shadow:
      0 6px 0 rgba(13, 10, 7, 0.3),
      0 12px 25px rgba(0, 0, 0, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.03);
  }

  .option-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .option-price {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .option-price strong {
    color: var(--color-accent);
    font-size: 1.2rem;
  }

  .option-example {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    opacity: 0.7;
    margin-top: 0.5rem;
  }

  .pricing-summary {
    background: rgba(255, 140, 66, 0.05);
    border: 1px solid rgba(255, 140, 66, 0.15);
    border-radius: 14px;
    padding: 1.5rem;
  }

  .pricing-summary p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    text-align: center;
  }

  .pricing-summary strong {
    color: var(--color-accent);
  }

  /* ===== Info Grid ===== */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .info-card {
    background: rgba(255, 180, 100, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow:
      0 3px 0 rgba(13, 10, 7, 0.4),
      0 6px 15px rgba(0, 0, 0, 0.2),
      inset 0 1px 2px rgba(255, 255, 255, 0.02);
  }

  .info-card:hover {
    border-color: rgba(255, 140, 66, 0.2);
    transform: translateY(-3px);
    box-shadow:
      0 6px 0 rgba(13, 10, 7, 0.3),
      0 12px 25px rgba(0, 0, 0, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.03);
  }

  .info-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .info-card h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .info-card p {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.5;
  }

  .info-sub {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Notice */
  .notice-card {
    background: rgba(255, 140, 66, 0.05);
    border: 1px solid rgba(255, 140, 66, 0.2);
    border-radius: 16px;
    padding: 1.75rem;
    text-align: center;
  }

  .notice-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .notice-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .notice-card strong {
    color: var(--color-text);
  }

  /* ===== Profile Card ===== */
  .profile-card {
    background: rgba(255, 180, 100, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2rem;
    box-shadow:
      0 4px 0 rgba(13, 10, 7, 0.5),
      0 8px 25px rgba(0, 0, 0, 0.3),
      inset 0 1px 2px rgba(255, 255, 255, 0.03);
  }

  .profile-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .stat-item {
    text-align: center;
    padding: 1rem;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .stat-value.rating {
    color: var(--color-accent);
  }

  .stat-sub {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* ===== CTA ===== */
  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(255, 180, 100, 0.02);
    border-radius: 24px;
    border: 1px solid var(--color-border);
  }

  .cta-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .cta-text {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 2.5rem;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent2) 100%);
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow:
      0 4px 0 #cc5a1a,
      0 8px 20px rgba(255, 140, 66, 0.3),
      inset 0 2px 4px rgba(255, 255, 255, 0.15);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow:
      0 6px 0 #cc5a1a,
      0 12px 30px rgba(255, 140, 66, 0.5),
      inset 0 2px 4px rgba(255, 255, 255, 0.15);
  }

  .cta-button:active {
    transform: translateY(2px);
    box-shadow:
      0 1px 0 #cc5a1a,
      0 4px 10px rgba(255, 140, 66, 0.2),
      inset 0 2px 4px rgba(255, 255, 255, 0.1);
  }

  .cta-icon {
    font-size: 1.5rem;
    font-weight: 700;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .mix-hero {
      min-height: 40vh;
    }

    .mix-hero-content {
      padding: 1.5rem;
    }

    .mix-hero-title {
      font-size: 2.5rem;
    }

    .mix-hero-subtitle {
      font-size: 1.5rem;
    }

    .mix-body {
      padding: 3rem 1.5rem;
    }

    .mix-section {
      margin-bottom: 4rem;
    }

    .section-label-bg {
      font-size: 4rem;
    }

    .service-card {
      padding: 2rem 1.5rem;
    }

    .pricing-header {
      padding: 2rem 1.5rem 1.5rem;
    }

    .price {
      font-size: 3rem;
    }

    .pricing-features {
      padding: 1.25rem 1.5rem 1.5rem;
    }

    .options-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .profile-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .cta-section {
      padding: 2.5rem 1.5rem;
    }

    .cta-button {
      padding: 1rem 2rem;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .mix-hero-title {
      font-size: 2rem;
    }

    .mix-hero-subtitle {
      font-size: 1.25rem;
    }

    .mix-body {
      padding: 2rem 1rem;
    }

    .section-label-bg {
      font-size: 3rem;
    }

    .mix-section-title {
      font-size: 1.5rem;
    }

    .service-card {
      padding: 1.5rem 1.25rem;
    }

    .detail-item {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }

    .price {
      font-size: 2.5rem;
